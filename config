[colors]
barBg = #ffD3CFB4
barShade = #ff807F6D
barFont = #ff38352C

[bar/down_bar]
font-0 = "ArialMTStd-Light:size=12:weight=light"
font-1 = "ArialMTSrd-Light:size=39:weight=medium;0"
font-2 = "DejaVu:size=20"
font-3 = "VL Gothic:size=20"
font-4 = "FontAwesome:size=40:weight=regular"
 
width=100%
height = 8%

background = #00;${colors.barBg}
border-size  = 20;40
border-top-size = 0
border-color = #00

bottom = true

underline-size=3
;underline-color= ${colors.barShade}
modules-left = example echo
modules-right = example


[bar/up_bar]
font-0 = "ArialMTStd-Light:size=20:weight=light;-5"

width=100%
height = 7%


background =#00000000
;${colors.barBg}
border-size  = 20;40
border-bottom-size = 0
border-color = #FF00

underline-size=15
underline-color=#00;${colors.barBg}


modules-center = i3

[module/i3]
type = internal/i3
format = <label-state> <label-mode>

; Available tokens:
;   %mode%
; Default: %mode%
label-mode = %mode%
label-mode-padding = 0
label-mode-background = #ffffffff
;#e60053


; Available tokens:
;   %name%
;   %icon%
;   %index%
;   %output%
; Default: %icon%  %name%
label-focused = %index%
label-focused-foreground = #ffffff
label-focused-background = ${colors.barShade}
label-focused-underline = ${colors.barShade}
label-focused-padding = 10
label-focused-margin = 5

; Available tokens:
;   %name%
;   %icon%
;   %index%
;   %output%
; Default: %icon%  %name%
label-unfocused = %index%
label-unfocused-padding = 10
label-unfocused-foreground = #ff000000
label-unfocused-background = ${colors.barBg}
label-unfocused-underline = #00000000
label-unfocused-margin=5

; Available tokens:
;   %name%
;   %icon%
;   %index%
;   %output%
; Default: %icon%  %name%
label-visible = %index%
label-visible-underline = #555555
label-visible-padding = 4


; Available tokens:
;   %name%
;   %icon%
;   %index%
;   %output%
; Default: %icon%  %name%
label-urgent = %index%
label-urgent-foreground = #000000
label-urgent-background = #bd2c40
label-urgent-padding = 4

; Separator in between workspaces
label-separator = |
label-separator-padding = 2
label-separator-foreground = #ffb52a


[module/echo]
type = custom/script
label = %output%
exec=/home/a/.config/polybar/scripts/echo.sh
interval = 1

label-font = 2

format-underline =${colors.barFont}
format-padding = 400
format-background = ${colors.barBg}

border-size=20

[module/workspace]
type = custom/script
exec=echo "nibba"

format-underline = ${colors.barFont}
format-background = ${colors.barShade}

[bar/tester]
width = 100%
height = 10%

background-color = #FFFF00FF
modules-center = text example
modules-left = example

font-0 = "ArialMTStd-Light:size=20:weight=light"
font-1 = "ArialMTSrd-Light:size=39:weight=medium;0"
font-2 = "DejaVu:size=20"
font-3 = "VL Gothic:size=20"
font-4 = "FontAwesome:size=40:weight=regular"

[module/text]
type = custom/text
content = Only Ketchup

[module/example]
type = custom/script
label = %output%
label-font=0
exec = echo "―"
label-background = #FFFF00FF
label-padding = 0

